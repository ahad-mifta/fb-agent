generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum KnowledgeSourceType {
  WEBSITE
  PDF
  FACEBOOK_POST
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

model FacebookPage {
  id              String            @id @default(cuid())
  pageId          String            @unique
  pageName        String
  pageAccessToken String
  isActive        Boolean           @default(true)
  lastPostSyncAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sources         KnowledgeSource[]
  posts           FacebookPost[]
  conversations   Conversation[]

  @@index([isActive])
}

model KnowledgeSource {
  id           String                @id @default(cuid())
  type         KnowledgeSourceType
  status       KnowledgeSourceStatus @default(PENDING)
  title        String
  url          String?
  fileName     String?
  text         String?
  error        String?
  facebookPageId String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  facebookPage FacebookPage?         @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)
  chunks       KnowledgeChunk[]
  post         FacebookPost?

  @@index([type])
  @@index([status])
}

model KnowledgeChunk {
  id        String                     @id @default(cuid())
  sourceId  String
  content   String
  position  Int
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                   @default(now())
  source    KnowledgeSource            @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
}

model FacebookPost {
  id             String          @id @default(cuid())
  pagePostId     String          @unique
  message        String
  permalinkUrl   String?
  publishedAt    DateTime?
  facebookPageId String
  sourceId       String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  facebookPage   FacebookPage    @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)
  source         KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([facebookPageId])
}

model Conversation {
  id             String              @id @default(cuid())
  facebookPageId String
  senderPsid     String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  facebookPage   FacebookPage        @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)
  messages       ConversationMessage[]

  @@unique([facebookPageId, senderPsid])
  @@index([updatedAt])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
